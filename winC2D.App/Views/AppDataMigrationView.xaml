<UserControl x:Class="winC2D.App.Views.AppDataMigrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Margin="10">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="{Binding L_Header}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <ui:Button Command="{Binding ScanCommand}" 
                       Appearance="Primary"
                       Margin="20,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14"/>
                    <TextBlock Text="{Binding L_Refresh}" Margin="5,0,0,0"/>
                </StackPanel>
            </ui:Button>
        </StackPanel>
        
        <!-- Search -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <ui:TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="{Binding L_Search}"
                       Icon="{ui:SymbolIcon Search24}"/>
        </Grid>
        
        <!-- AppData List -->
        <ui:DataGrid Grid.Row="2"
                    x:Name="AppDataDataGrid"
                    ItemsSource="{Binding AppDataItems}"
                    AutoGenerateColumns="False"
                    IsReadOnly="False"
                    CanUserSortColumns="True"
                    SelectionMode="Extended"
                    Sorting="AppDataDataGrid_Sorting">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="36" MinWidth="36" MaxWidth="36"
                                        CanUserResize="False"
                                        IsReadOnly="False"/>
                <DataGridTextColumn Header="{Binding DataContext.L_ColName, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Name}" SortMemberPath="Name" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="{Binding DataContext.L_ColPath, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Path}" SortMemberPath="Path" IsReadOnly="True" Width="300"/>
                <DataGridTextColumn Header="{Binding DataContext.L_ColType, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Type}" SortMemberPath="Type" IsReadOnly="True" Width="80"/>
                <DataGridTemplateColumn Header="{Binding DataContext.L_ColSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        SortMemberPath="SizeBytes"
                                        CanUserSort="True"
                                        Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock x:Name="SizeText"
                                           Text="{Binding SizeText}"
                                           Padding="4,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <ui:Button x:Name="CheckSizeButton"
                                           Command="{Binding DataContext.CheckSizeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           Content="{Binding DataContext.L_CheckSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Appearance="Secondary"
                                           Padding="6,0"
                                           MinHeight="24"/>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding SizeChecked}" Value="True">
                                    <Setter TargetName="SizeText" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="CheckSizeButton" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{Binding DataContext.L_ColStatus, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Status}" SortMemberPath="Status" IsReadOnly="True" Width="80"/>
            </DataGrid.Columns>
        </ui:DataGrid>
        
        <!-- Target and Actions -->
        <Grid Grid.Row="3" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                <TextBlock Text="{Binding L_Target}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ui:TextBox Width="320"
                            Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"/>
                <ui:Button Command="{Binding BrowsePathCommand}"
                           Content="{Binding L_BrowsePath}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <ui:Button Command="{Binding MigrateCommand}"
                          Appearance="Primary"
                          IsEnabled="{Binding IsMigrating, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowRight24" FontSize="14"/>
                        <TextBlock Text="{Binding L_Migrate}" Margin="5,0,0,0"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Grid>
        
        <!-- Status -->
        <StatusBar Grid.Row="4">
            <TextBlock Text="{Binding StatusMessage}"/>
        </StatusBar>
    </Grid>
</UserControl>
