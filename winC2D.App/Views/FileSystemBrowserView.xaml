<UserControl x:Class="winC2D.App.Views.FileSystemBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:winC2D.App.ViewModels"
             xmlns:models="clr-namespace:winC2D.Core.Models;assembly=winC2D.Core"
             Margin="0">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="160" MaxWidth="380"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════ -->
        <!-- LEFT SIDEBAR -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Quick Access header -->
            <TextBlock Grid.Row="0" Text="★ 快速访问" FontWeight="SemiBold" FontSize="13"
                       Margin="12,10,12,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

            <!-- Quick Access list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding QuickAccessItems}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="4,0"
                     MaxHeight="260"
                     SelectionMode="Single">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Button Command="{Binding DataContext.NavigateQuickAccessCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Cursor="Hand"
                                            HorizontalContentAlignment="Stretch">
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                    </Button>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:QuickAccessItem}">
                        <Grid Background="Transparent" Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Folder24" FontSize="16"
                                           VerticalAlignment="Center" Margin="8,4,6,4"
                                           Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                       VerticalAlignment="Center" FontSize="12" Margin="0,4,8,4"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Separator -->
            <Separator Grid.Row="2" Margin="12,6"/>

            <!-- This PC header -->
            <TextBlock Grid.Row="3" Text="🖴 此电脑" FontWeight="SemiBold" FontSize="13"
                       Margin="12,0,12,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

            <!-- Drive list -->
            <ListBox Grid.Row="4"
                     ItemsSource="{Binding Drives}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="4,0"
                     SelectionMode="Single">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Button Command="{Binding DataContext.NavigateDriveCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4,3"
                                            Cursor="Hand"
                                            HorizontalContentAlignment="Stretch">
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                    </Button>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:DriveItem}">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:SymbolIcon Grid.RowSpan="2" Grid.Column="0"
                                           Symbol="HardDrive24" FontSize="20"
                                           VerticalAlignment="Center" Margin="6,0,8,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{Binding Label, StringFormat=' ({0})'}" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="3,0,0,0"/>
                            </StackPanel>

                            <!-- Free space bar -->
                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,3,8,4">
                                <ProgressBar Value="{Binding UsagePercent, Mode=OneWay}" Maximum="100" Height="4"
                                             Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                             Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- GridSplitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                       ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                       Background="{DynamicResource CardStrokeColorDefaultBrush}"/>

        <!-- ══════════════════════════════════════════ -->
        <!-- RIGHT MAIN CONTENT -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="2" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Breadcrumb -->
                <RowDefinition Height="Auto"/>   <!-- Toolbar -->
                <RowDefinition Height="*"/>      <!-- DataGrid -->
                <RowDefinition Height="Auto"/>   <!-- Selection info -->
                <RowDefinition Height="Auto"/>   <!-- Target + Actions -->
                <RowDefinition Height="Auto"/>   <!-- Progress bars -->
            </Grid.RowDefinitions>

            <!-- ── Breadcrumb ──────────────────────────── -->
            <ItemsControl Grid.Row="0" ItemsSource="{Binding Breadcrumbs}"
                          Margin="0,4,0,8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BreadcrumbItem}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Separator arrow (hidden for root item via style trigger) -->
                            <TextBlock Text=" ▸ " FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRoot}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Clickable crumb -->
                            <Button Command="{Binding DataContext.NavigateBreadcrumbCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4,2"
                                    Cursor="Hand">
                                <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Toolbar ────────────────────────────── -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Navigation buttons -->
                <StackPanel Orientation="Horizontal">
                    <ui:Button Command="{Binding NavigateUpCommand}"
                               ToolTip="向上一级"
                               Appearance="Secondary" Margin="0,0,4,0"
                               Width="32" Height="28" Padding="4">
                        <ui:SymbolIcon Symbol="ArrowUp24" FontSize="14"/>
                    </ui:Button>
                    <ui:Button Command="{Binding RefreshCommand}"
                               ToolTip="刷新"
                               Appearance="Secondary" Margin="0,0,4,0"
                               Width="32" Height="28" Padding="4">
                        <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14"/>
                    </ui:Button>

                    <!-- Add to Quick Access -->
                    <ui:Button Command="{Binding AddToQuickAccessCommand}"
                               ToolTip="添加到快速访问"
                               Appearance="Secondary" Margin="0,0,8,0"
                               Width="32" Height="28" Padding="4">
                        <ui:SymbolIcon Symbol="Pin24" FontSize="14"/>
                    </ui:Button>

                    <!-- Current path display -->
                    <TextBlock Text="{Binding CurrentPath, TargetNullValue=此电脑}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"
                               Margin="4,0"/>
                </StackPanel>

                <!-- Scan + selection buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Command="{Binding ScanSizesCommand}"
                               Appearance="Primary"
                               IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}"
                               Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DataUsage24" FontSize="14"/>
                            <TextBlock Text="扫描大小" Margin="4,0,0,0"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button Command="{Binding SelectAllCommand}" Content="全选"
                               Appearance="Secondary" Margin="0,0,2,0"
                               IsEnabled="{Binding IsMigrating, Converter={StaticResource InverseBooleanConverter}}"/>
                    <ui:Button Command="{Binding DeselectAllCommand}" Content="取消"
                               Appearance="Secondary"
                               IsEnabled="{Binding IsMigrating, Converter={StaticResource InverseBooleanConverter}}"/>
                </StackPanel>
            </Grid>

            <!-- ── DataGrid ───────────────────────────── -->
            <DataGrid Grid.Row="2"
                      x:Name="FileSystemDataGrid"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserSortColumns="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      MouseDoubleClick="DataGrid_MouseDoubleClick"
                      Background="{DynamicResource CardBackgroundBrush}">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Checkbox -->
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="36" MinWidth="36" MaxWidth="36"
                                            CanUserResize="False" IsReadOnly="False"/>

                    <!-- Name with icon -->
                    <DataGridTemplateColumn Header="名称" Width="*" SortMemberPath="Name"
                                            CanUserSort="True" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:FileSystemItem}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol" Value="Document24"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                        <Setter Property="Symbol" Value="Folder24"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Size -->
                    <DataGridTextColumn Header="大小" Binding="{Binding SizeText, Mode=OneWay}"
                                        SortMemberPath="SizeBytes" Width="90"
                                        IsReadOnly="True"/>

                    <!-- Status -->
                    <DataGridTemplateColumn Header="状态" SortMemberPath="Status" Width="80"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:FileSystemItem}">
                                <TextBlock Text="{Binding Status,
                                            Converter={StaticResource FileSystemItemStatusConverter}}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Type -->
                    <DataGridTextColumn Header="类型" Binding="{Binding TypeText}"
                                        SortMemberPath="TypeText" Width="100"
                                        IsReadOnly="True"/>

                    <!-- Path -->
                    <DataGridTextColumn Header="路径" Binding="{Binding FullPath}"
                                        SortMemberPath="FullPath" Width="280"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── Selection Info ─────────────────────── -->
            <Border Grid.Row="3" Margin="0,8,0,4" Padding="8,4"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="已选: " FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="{Binding TotalSelectedCount}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                    <TextBlock Text=" 个项目 (" Margin="0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="{Binding TotalSelectedSizeText}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                    <TextBlock Text=")" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- ── Target + Migrate ───────────────────── -->
            <Grid Grid.Row="4" Margin="0,4,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="目标路径:" VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:TextBox Grid.Column="1"
                            Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"
                            PlaceholderText="输入迁移目标目录…"
                            MinWidth="200"/>

                <ui:Button Grid.Column="2"
                           Command="{Binding BrowseTargetPathCommand}"
                           Content="浏览…"
                           Appearance="Secondary"
                           Margin="6,0,6,0"
                           VerticalAlignment="Center"/>

                <ui:Button Grid.Column="3"
                           Command="{Binding MigrateCommand}"
                           Appearance="Primary"
                           IsEnabled="{Binding IsMigrating, Converter={StaticResource InverseBooleanConverter}}"
                           VerticalAlignment="Center"
                           MinWidth="100">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowRight24" FontSize="14"/>
                        <TextBlock Text="迁移选中" Margin="4,0,0,0"/>
                    </StackPanel>
                </ui:Button>
            </Grid>

            <!-- ── Progress Bars ──────────────────────── -->
            <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scan progress -->
                <Grid Grid.Row="0"
                      Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Margin="0,0,0,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <ui:ProgressRing Width="14" Height="14" IsIndeterminate="True"
                                         Margin="0,0,6,0"/>
                        <TextBlock Text="扫描中：" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding CurrentScanDirectory}" FontSize="11"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>
                    <ProgressBar Grid.Row="1" Value="{Binding ScanProgress}" Maximum="100"
                                 Height="3" Minimum="0"/>
                </Grid>

                <!-- Migration progress -->
                <Grid Grid.Row="1"
                      Visibility="{Binding IsMigrating, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <ui:ProgressRing Width="14" Height="14" IsIndeterminate="True"
                                         Margin="0,0,6,0"/>
                        <TextBlock Text="迁移中…" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ProgressBar Grid.Row="1" Value="{Binding MigrationProgress}" Maximum="100"
                                 Height="3" Minimum="0"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
