<UserControl x:Class="winC2D.App.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Margin="10">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ui:SymbolIcon Symbol="History24" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="{Binding L_Header}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <ui:Button Command="{Binding LoadLogsCommand}" 
                       Appearance="Primary"
                       Margin="20,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14"/>
                    <TextBlock Text="{Binding L_Refresh}" Margin="5,0,0,0"/>
                </StackPanel>
            </ui:Button>
        </StackPanel>
        
        <!-- Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox Content="{Binding L_ShowSuccessful}" IsChecked="{Binding ShowSuccessful}" Margin="0,0,15,0"/>
            <CheckBox Content="{Binding L_ShowFailed}" IsChecked="{Binding ShowFailed}" Margin="0,0,15,0"/>
            <CheckBox Content="{Binding L_ShowRolledBack}" IsChecked="{Binding ShowRolledBack}"/>
        </StackPanel>
        
        <!-- Log List -->
        <ui:DataGrid Grid.Row="2"
                    ItemsSource="{Binding LogEntries}"
                    SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding DataContext.L_ColTime, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                <DataGridTextColumn Header="{Binding DataContext.L_ColType, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Type}" Width="80"/>
                <DataGridTextColumn Header="{Binding DataContext.L_ColSource, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding SourcePath}" Width="*"/>
                <DataGridTextColumn Header="{Binding DataContext.L_ColTarget, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding TargetPath}" Width="*"/>
                <DataGridTextColumn Header="{Binding DataContext.L_ColStatus, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </ui:DataGrid>
        
        <!-- Actions -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button Command="{Binding RollbackCommand}"
                          Content="{Binding L_RollbackSelected}"
                          IsEnabled="{Binding SelectedEntry, Converter={StaticResource NullToBooleanConverter}}"
                          Margin="0,0,10,0"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Command="{Binding ExportLogCommand}" Content="{Binding L_ExportLog}" Margin="0,0,10,0"/>
                <ui:Button Command="{Binding ClearLogCommand}" Content="{Binding L_ClearHistory}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>