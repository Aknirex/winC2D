<UserControl x:Class="winC2D.App.Views.SoftwareMigrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:winC2D.App.ViewModels"
             Margin="10">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ui:SymbolIcon Symbol="Apps24" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="{Binding L_Header}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <!-- Quick scan (uses cache) -->
            <ui:Button Command="{Binding ScanCommand}" 
                       Appearance="Secondary"
                       Margin="20,0,6,0"
                       IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14"/>
                    <TextBlock Text="{Binding L_Refresh}" Margin="5,0,0,0"/>
                </StackPanel>
            </ui:Button>
            <!-- Full refresh (calculates exact sizes and writes cache) -->
            <ui:Button Command="{Binding RefreshCommand}" 
                       Appearance="Primary"
                       IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowSyncCheckmark24" FontSize="14"/>
                    <TextBlock Text="{Binding L_FullRefresh}" Margin="5,0,0,0"/>
                </StackPanel>
            </ui:Button>
        </StackPanel>

        <!-- Scan progress bar (visible only while scanning) -->
        <Grid Grid.Row="1" Margin="0,0,0,10"
              Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar Value="{Binding ScanProgress}" Maximum="100" Height="4"
                         IsIndeterminate="{Binding IsScanning}"
                         Minimum="0"/>
        </Grid>
        
        <!-- Search -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <ui:TextBox Grid.Column="0" 
                       Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="{Binding L_Search}"
                       Icon="{ui:SymbolIcon Search24}"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                <ui:Button Command="{Binding SelectAllCommand}" Content="{Binding L_SelectAll}" Margin="0,0,5,0"/>
                <ui:Button Command="{Binding DeselectAllCommand}" Content="{Binding L_DeselectAll}"/>
            </StackPanel>
        </Grid>
        
        <!-- Software List -->
        <ui:DataGrid Grid.Row="3"
                    x:Name="SoftwareDataGrid"
                    ItemsSource="{Binding SoftwareItems}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    CanUserSortColumns="True"
                    SelectionMode="Extended"
                    PreviewMouseRightButtonDown="SoftwareDataGrid_PreviewMouseRightButtonDown">

            <!-- Row right-click context menu — PlacementTarget is the DataGrid itself -->
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding PlacementTarget.DataContext.L_MenuOpenExplorer,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Command="{Binding PlacementTarget.DataContext.OpenInExplorerCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext.RightClickedItem,
                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="FolderOpen24"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{Binding PlacementTarget.DataContext.L_MenuCopyPath,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Command="{Binding PlacementTarget.DataContext.CopyPathCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext.RightClickedItem,
                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Copy24"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <!-- Fixed-width checkbox column -->
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay}"
                                        Width="36" MinWidth="36" MaxWidth="36"
                                        CanUserResize="False"/>

                <!-- Name -->
                <DataGridTextColumn Header="{Binding DataContext.L_ColName,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Binding="{Binding Name}"
                                    SortMemberPath="Name"
                                    Width="*"/>

                <!-- Path -->
                <DataGridTextColumn Header="{Binding DataContext.L_ColPath,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Binding="{Binding InstallLocation}"
                                    SortMemberPath="InstallLocation"
                                    Width="300"/>

                <!-- Size with tooltip explaining "> 10 MB" -->
                <DataGridTemplateColumn Header="{Binding DataContext.L_ColSize,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        SortMemberPath="SizeBytes"
                                        Width="90"
                                        CanUserSort="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SizeText}" Padding="4,0"
                                       ToolTip="{Binding .,
                                                 Converter={StaticResource SizeCellTooltipConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status with localized text and tooltip -->
                <DataGridTemplateColumn Header="{Binding DataContext.L_ColStatus,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        SortMemberPath="Status"
                                        Width="100"
                                        CanUserSort="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status,
                                               Converter={StaticResource SoftwareStatusTextConverter}}"
                                       Padding="4,0"
                                       ToolTip="{Binding .,
                                                 Converter={StaticResource StatusCellTooltipConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </ui:DataGrid>
        
        <!-- Selection Info -->
        <Grid Grid.Row="4" Margin="0,10,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Selected: " FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="{Binding TotalSelectedCount}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text=" items (" Margin="5,0,0,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="{Binding TotalSelectedSize}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text=" bytes)"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </Grid>
        
        <!-- Target and Actions -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <WrapPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0"
                       VerticalAlignment="Center">
                <TextBlock Text="{Binding L_TargetDisk}" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ComboBox Width="80"
                          SelectedItem="{Binding TargetDisk}"
                          ItemsSource="{Binding AvailableDrives}"
                          Margin="0,0,16,0"/>
                <TextBlock Text="{Binding L_TargetPath}" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:TextBox Width="200" Text="{Binding TargetPath}" VerticalAlignment="Center"
                            Margin="0,0,6,0"/>
                <ui:Button Command="{Binding BrowsePathCommand}"
                           Content="{Binding L_BrowsePath}"
                           VerticalAlignment="Center"/>
            </WrapPanel>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <ui:Button Command="{Binding MigrateCommand}"
                          Appearance="Primary"
                          IsEnabled="{Binding IsMigrating, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowRight24" FontSize="14"/>
                        <TextBlock Text="{Binding L_Migrate}" Margin="5,0,0,0"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Grid>
        
        <!-- Migration progress bar (shown during migration) -->
        <Grid Grid.Row="6" Visibility="{Binding IsMigrating, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar Value="{Binding MigrationProgress}" Maximum="100" Height="4" Margin="0,8,0,0"/>
        </Grid>
    </Grid>
</UserControl>