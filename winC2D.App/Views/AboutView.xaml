<UserControl x:Class="winC2D.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Margin="10">
    
    <ScrollViewer>
        <StackPanel>
            <!-- Header -->
            <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,20"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                <Run Text="{Binding L_Header, Mode=OneWay}"/>
            </TextBlock>
            
            <!-- Application Info -->
            <ui:Card Margin="0,0,0,10">
                <StackPanel Margin="20">
                    <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,10">
                        <Run Text="{Binding L_Title, Mode=OneWay}"/>
                    </TextBlock>
                    
                    <TextBlock Margin="0,0,0,5">
                        <Run Text="{Binding L_Version, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,0,0,5">
                        <Run Text="{Binding L_License, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,0,0,5">
                        <Run Text="{Binding L_Author, Mode=OneWay}"/>
                    </TextBlock>
                    
                    <TextBlock TextWrapping="Wrap" Margin="0,10,0,0">
                        <Run Text="{Binding L_Description, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </ui:Card>
            
            <!-- Links -->
            <ui:Card Margin="0,0,0,10">
                <StackPanel Margin="20">
                    <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,10">
                        <Run Text="{Binding L_LinksHeader, Mode=OneWay}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <ui:SymbolIcon Symbol="Globe24" Margin="0,0,10,0"/>
                        <TextBlock>
                            <Hyperlink NavigateUri="{Binding RepositoryUri}"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="{Binding L_Repository, Mode=OneWay}"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <ui:SymbolIcon Symbol="Book24" Margin="0,0,10,0"/>
                        <TextBlock>
                            <Hyperlink NavigateUri="{Binding DocumentationUri}"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="{Binding L_Documentation, Mode=OneWay}"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <ui:SymbolIcon Symbol="Bug24" Margin="0,0,10,0"/>
                        <TextBlock>
                            <Hyperlink NavigateUri="https://github.com/Aknirex/winC2D/issues"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="{Binding L_IssueTracker, Mode=OneWay}"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </ui:Card>
            
            <!-- Disclaimer -->
            <ui:Card Margin="0,0,0,10">
                <StackPanel Margin="20">
                    <TextBlock FontSize="14" FontWeight="Bold" Margin="0,0,0,5">
                        <Run Text="{Binding L_DisclaimerTitle, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="{Binding L_DisclaimerText, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
