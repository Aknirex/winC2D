<ui:FluentWindow x:Class="winC2D.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:winC2D.App.Views"
        xmlns:vm="clr-namespace:winC2D.App.ViewModels"
        Title="{Binding Title}"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True">
    
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </ui:FluentWindow.Resources>
    
    <ui:FluentWindow.TitleBar>
        <ui:TitleBar Title="{Binding Title}" ShowMinimize="True" ShowMaximize="True" ShowClose="True"/>
    </ui:FluentWindow.TitleBar>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Navigation -->
        <ui:NavigationView Grid.Row="1" 
                          SelectedPageIndex="{Binding SelectedNavigationIndex, Mode=TwoWay}">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Icon="{ui:SymbolIcon Software}" Content="Software Migration">
                    <ui:NavigationViewItem.Tag>
                        <views:SoftwareMigrationView/>
                    </ui:NavigationViewItem.Tag>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="{ui:SymbolIcon Folder}" Content="AppData">
                    <ui:NavigationViewItem.Tag>
                        <views:AppDataMigrationView/>
                    </ui:NavigationViewItem.Tag>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="{ui:SymbolIcon Settings}" Content="Settings">
                    <ui:NavigationViewItem.Tag>
                        <views:SettingsView/>
                    </ui:NavigationViewItem.Tag>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="{ui:SymbolIcon History}" Content="Logs">
                    <ui:NavigationViewItem.Tag>
                        <views:LogView/>
                    </ui:NavigationViewItem.Tag>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
            
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Icon="{ui:SymbolIcon Question}" Content="About">
                    <ui:NavigationViewItem.Tag>
                        <views:AboutView/>
                    </ui:NavigationViewItem.Tag>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" 
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Language: " 
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                             SelectedValuePath="Code"
                             DisplayMemberPath="NativeName"
                             SelectedValue="{Binding CurrentLanguage}"
                             Width="120"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>